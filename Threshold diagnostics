    data = threshold_line_data,
    aes(xintercept = threshold_log),
    inherit.aes = FALSE,
    linetype = "dashed",
    linewidth = 0.35,
    colour = "grey35"
  ) +
  geom_hline(
    data = prop_line_data,
    aes(yintercept = threshold),
    inherit.aes = FALSE,
    linetype = "dotted",
    linewidth = 0.35,
    colour = "grey35"
  ) +
  annotate(
    "text",
    x = threshold_line_data$threshold_log,
    y = 0.02,
    label = paste0(threshold_line_data$threshold, " km2"),
    angle = 90,
    vjust = -0.35,
    hjust = 0,
    size = 3.2,
    colour = "black"
  ) +
  annotate(
    "text",
