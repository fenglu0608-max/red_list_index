save_plot(p_mainland, "02_mainland_side_area_proportion_thresholds", width = 8.8, height = 5.6)

# ------------------------------------------------------------
# 3. Island area versus mainland area
# ------------------------------------------------------------

p_area_area <- ggplot(
  plot_dat %>% filter(has_terrestrial_overlap),
  aes(
    x = log_mainland_area,
    y = log_true_island_area,
    colour = land_distribution_class
  )
) +
  geom_abline(
    intercept = 0,
    slope = 1,
    linetype = "solid",
    linewidth = 0.25,
    colour = "grey55"
  ) +
  geom_point(alpha = 0.35, size = 1.1) +
  geom_vline(
    data = threshold_line_data,
    aes(xintercept = threshold_log),
    inherit.aes = FALSE,
    linetype = "dashed",
    linewidth = 0.35,
    colour = "grey35"
  ) +
  geom_hline(
    data = threshold_line_data,
    aes(yintercept = threshold_log),
    inherit.aes = FALSE,
    linetype = "dashed",
    linewidth = 0.35,
    colour = "grey35"
  ) +
  scale_x_continuous(
    breaks = axis_area_breaks_log,
    labels = axis_area_labels
  ) +
  scale_y_continuous(
    breaks = axis_area_breaks_log,
    labels = axis_area_labels
  ) +
  scale_colour_manual(values = class_cols, drop = FALSE) +
  labs(
    x = "Mainland overlap area (km2, log10 area + 1)",
    y = "True-island overlap area (km2, log10 area + 1)",
    title = "Island and mainland overlap areas",
    subtitle = "The diagonal indicates equal island and mainland overlap area"
  ) +
  base_theme

save_plot(p_area_area, "03_island_area_vs_mainland_area", width = 7.2, height = 5.8)

# ------------------------------------------------------------
# 4. Sensitivity of species counts to area and proportion thresholds
# ------------------------------------------------------------

sensitivity <- expand.grid(
  area_threshold_km2 = area_thresholds,
  prop_threshold = prop_thresholds,
  group = c("Island-side", "Mainland-side")
) %>%
  as_tibble() %>%
  rowwise() %>%
  mutate(
    n_species = ifelse(
      group == "Island-side",
      sum(
        species$true_island_area_km2 > 0 &
          species$mainland_area_km2 <= area_threshold_km2 &
          species$true_island_prop_land >= prop_threshold &
          !species$any_area_failed,
        na.rm = TRUE
      ),
      sum(
        species$mainland_area_km2 > 0 &
          species$true_island_area_km2 <= area_threshold_km2 &
          species$mainland_prop_land >= prop_threshold &
          !species$any_area_failed,
        na.rm = TRUE
      )
    )
  ) %>%
  ungroup() %>%
  mutate(
    area_threshold_label = paste0(area_threshold_km2, " km2"),
    prop_threshold_label = paste0(prop_threshold * 100, "%")
  )

fwrite(
  sensitivity,
  file.path(out_dir, "threshold_sensitivity_species_counts.csv")
)

p_sensitivity <- ggplot(
  sensitivity,
  aes(
    x = area_threshold_label,
    y = prop_threshold_label,
    fill = n_species
  )
) +
  geom_tile(colour = "white", linewidth = 0.7) +
  geom_text(
    aes(label = n_species),
    size = 4.2,
    fontface = "bold",
    colour = "black"
  ) +
  facet_wrap(~ group) +
  scale_fill_gradient(
    low = "#F3F3F3",
    high = "#3B6EA8",
    name = "Species"
  ) +
  labs(
    x = "Allowed opposite-land overlap area",
    y = "Required land proportion",
    title = "Threshold sensitivity",
    subtitle = "Counts show how many species meet each area/proportion combination"
  ) +
  base_theme +
  theme(legend.position = "right")

save_plot(p_sensitivity, "04_threshold_sensitivity_heatmap", width = 7.8, height = 4.8)

# ------------------------------------------------------------
# 5. Species near threshold boundaries for manual checking
# ------------------------------------------------------------

near_island_boundary <- species %>%
  filter(
    !any_area_failed,
    true_island_area_km2 > 0,
    true_island_prop_land >= 0.90,
    mainland_area_km2 > 1
  ) %>%
  mutate(
    diagnostic_group = "Island-like but mainland overlap exceeds 1 km2",
    opposite_area_km2 = mainland_area_km2,
    focal_prop_land = true_island_prop_land
  )

near_mainland_boundary <- species %>%
  filter(
    !any_area_failed,
    mainland_area_km2 > 0,
    mainland_prop_land >= 0.90,
    true_island_area_km2 > 1
  ) %>%
  mutate(
    diagnostic_group = "Mainland-like but island overlap exceeds 1 km2",
    opposite_area_km2 = true_island_area_km2,
    focal_prop_land = mainland_prop_land
  )

near_boundary_species <- bind_rows(
  near_island_boundary,
  near_mainland_boundary
) %>%
  mutate(
    opposite_area_bin = case_when(
      opposite_area_km2 <= 10 ~ "1-10 km2",
      opposite_area_km2 <= 100 ~ "10-100 km2",
      opposite_area_km2 <= 1000 ~ "100-1000 km2",
      TRUE ~ ">1000 km2"
    ),
    focal_prop_bin = case_when(
      focal_prop_land >= 0.99 ~ ">=99%",
      focal_prop_land >= 0.95 ~ "95-99%",
      TRUE ~ "90-95%"
    )
  ) %>%
  arrange(diagnostic_group, desc(focal_prop_land), opposite_area_km2)

fwrite(
  near_boundary_species,
  file.path(out_dir, "near_boundary_species_for_manual_check.csv")
)

boundary_counts <- near_boundary_species %>%
  count(diagnostic_group, opposite_area_bin, focal_prop_bin, name = "n_species")

fwrite(
  boundary_counts,
  file.path(out_dir, "near_boundary_species_counts.csv")
)

p_boundary <- ggplot(
  boundary_counts,
  aes(x = opposite_area_bin, y = focal_prop_bin, fill = n_species)
) +
  geom_tile(colour = "white", linewidth = 0.7) +
  geom_text(
    aes(label = n_species),
    size = 3.8,
    fontface = "bold",
    colour = "black"
  ) +
  facet_wrap(~ diagnostic_group) +
  scale_fill_gradient(
    low = "#F3F3F3",
    high = "#D55E00",
    name = "Species"
  ) +
  labs(
    x = "Opposite-land overlap area",
    y = "Focal land proportion",
    title = "Boundary species for manual checking",
    subtitle = "These species are island-like or mainland-like but exceed the strict 1 km2 area tolerance"
  ) +
  base_theme

save_plot(p_boundary, "05_near_boundary_species_heatmap", width = 9.6, height = 4.8)

